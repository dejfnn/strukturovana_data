{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "{{BASE_URL}}/#website",
  "url": "{{BASE_URL}}",
  "name": "{{SITE_NAME}}",
  "description": "{{DESCRIPTION}}",
  "publisher": {
    "@id": "{{BASE_URL}}/#organization"
  },
  "inLanguage": ["{{LANGUAGE_CODE}}"],
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{BASE_URL}}/?s={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
